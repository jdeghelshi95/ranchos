---
import { Image } from "astro:assets";

interface Props {
  /** The image to display — import it and pass the result here */
  src: ImageMetadata;
  /** Alt text for accessibility (leave empty string if purely decorative) */
  alt?: string;
  /**
   * Controls how tall the banner is at each breakpoint.
   * Defaults: mobile 40vh · tablet 55vh · desktop 70vh
   * Override by passing e.g. height={{ mobile: "50vh", tablet: "60vh", desktop: "80vh" }}
   */
  height?: {
    mobile?: string;
    tablet?: string;
    desktop?: string;
  };
}

const {
  src,
  alt = "",
  height = {},
} = Astro.props;

const mobileH  = height.mobile  ?? "40vh";
const tabletH  = height.tablet  ?? "55vh";
const desktopH = height.desktop ?? "70vh";
---

<div
  class="banner-wrap"
  style={`
    --h-mobile:  ${mobileH};
    --h-tablet:  ${tabletH};
    --h-desktop: ${desktopH};
  `}
>
  <Image
    src={src}
    alt={alt}
    widths={[640, 1280, 1920, 2560]}
    sizes="100vw"
    class="banner-img"
  />
  <!-- Optional overlay content (e.g. a heading) -->
  <div class="banner-slot">
    <slot />
  </div>
</div>

<style>
  .banner-wrap {
    position: relative;
    width: 100%;
    height: var(--h-mobile);
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .banner-wrap { height: var(--h-tablet); }
  }

  @media (min-width: 1280px) {
    .banner-wrap { height: var(--h-desktop); }
  }

  .banner-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  /* Slot sits above the image */
  .banner-slot {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>